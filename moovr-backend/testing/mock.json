          "make": "string",
          "model": "string",
          "description": "string",
          "price": "number",
          "image": "string",
          "status": "active | inactive | removed"
        }
      }
    },
    {
      "name": "Get Car Listing by ID",
      "method": "GET",
      "url": "/api/v1/cars/list/:id",
      "headers": {
        "Authorization": "Bearer {token}"
      },
      "response": {
        "carListing": {
          "vehicleName": "string",
