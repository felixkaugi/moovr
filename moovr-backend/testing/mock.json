      },
      "request_body": {
        "vehicleName": "string",
        "make": "string",
        "model": "string",
        "description": "string",
        "price": "number",
        "image": "file"
      },
      "response": {
        "message": "Car listing updated successfully",
        "carListing": {
          "vehicleName": "string",
          "make": "string",
          "model": "string",
          "description": "string",
          "price": "number",
          "image": "string"
        }
      }
    },
    {
      "name": "Get All Car Listings",
      "method": "GET",
      "url": "/api/v1/cars/list",
      "response": {
